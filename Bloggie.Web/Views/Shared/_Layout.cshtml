@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> signInManager;

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bloggie</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">Bloggie</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Blogs">Blogs</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/Login">Login</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Account/Register">Register</a></li>
                        <li class="nav-item"><a class="nav-link" href="/AdminTags/List">Tags</a></li>
                        <li class="nav-item"><a class="nav-link" href="/AdminBlogPost/List">Admin</a></li>
                    </ul>
                </div>
            </div>
        </nav>
        <div class="bg-primary bg-gradient text-white py-4 mb-4">
            <div class="container text-center">
                <h1 class="display-5 fw-bold">Welcome to Bloggie</h1>
                <p class="lead">Share your thoughts, read others, and join the conversation!</p>
            </div>
        </div>
    </header>
    <main role="main" class="container mb-5">
        @RenderBody()
    </main>
    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-0">&copy; @DateTime.Now.Year Bloggie. All rights reserved.</p>
            <p class="mb-0 small">Powered by ASP.NET Core Razor Pages</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
